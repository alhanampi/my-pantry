datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  linksAsUser  UserLink[] @relation("UserLinks")
  linksAsPartner UserLink[] @relation("PartnerLinks")
}

model UserLink {
  id        Int      @id @default(autoincrement())
  userId    Int
  partnerId Int
  createdAt DateTime @default(now())

  user    User @relation("UserLinks",   fields: [userId],    references: [id], onDelete: Cascade)
  partner User @relation("PartnerLinks", fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([userId, partnerId])
}
